NODE_ENV="development"
LOG_LEVEL="info"
RISKDELTA_EDITION="community-source-available"

# Shared infra
DATABASE_URL="postgresql://riskdelta:riskdelta@localhost:5433/riskdelta?schema=public"
REDIS_URL="redis://localhost:6380"
ENCRYPTION_KEY="replace-with-at-least-32-characters-secret-key-value"

# MinIO
MINIO_ENDPOINT="127.0.0.1"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="riskdelta_minio"
MINIO_SECRET_KEY="replace-with-long-secret"
MINIO_BUCKET="riskdelta-evidence"
MINIO_USE_SSL="false"

# Web
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_RISKDELTA_EDITION="community-source-available"
RISKDELTA_API_URL="http://localhost:4100"
AUTH_SECRET="replace-with-at-least-32-characters-auth-secret"
DEMO_USER_EMAIL="founder@riskdelta.dev"
DEMO_USER_PASSWORD="replace-with-strong-demo-password"

# API
API_HOST="0.0.0.0"
API_PORT="4100"
WEB_APP_ORIGIN="http://localhost:3000"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
API_RATE_LIMIT_MAX="200"
API_RATE_LIMIT_WINDOW="1 minute"

# Worker
WORKER_CONCURRENCY="5"
